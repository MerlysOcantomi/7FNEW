AUTH_SECRET=replace-with-a-long-random-secret

# Database (use either DATABASE_* or TURSO_*)
DATABASE_URL=libsql://your-database-url
DATABASE_AUTH_TOKEN=your-database-auth-token
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# AI providers
OPENAI_API_KEY=

# CORE-VOICE-0B: isolated Realtime Voice Lab. Disabled unless exactly "true".
# Gate also requires platform admin/dev + a valid workspace. Leave empty in prod.
VOICE_LAB_ENABLED=

# DEV-PREVIEW-01A: Mr Forte Lab (/lab). Fail-closed — ALL conditions must hold
# or /lab answers 404. Only set these in the DEDICATED Lab Vercel project;
# NEVER in the Sevenef production project. See docs/lab-preview.md.
SEVENEF_LAB_PREVIEW_ENABLED=
# Must be exactly "dedicated".
SEVENEF_LAB_DEPLOYMENT_MODE=
# The Lab Vercel project id (compared exactly against VERCEL_PROJECT_ID).
SEVENEF_LAB_EXPECTED_PROJECT_ID=
# Comma-separated exact hostnames (host[:port]); no wildcards.
SEVENEF_LAB_ALLOWED_HOSTS=
# Local `next dev` opt-in (exact "true"); all other conditions still apply.
SEVENEF_LAB_LOCAL_DEV_ENABLED=

# DEV-PREVIEW-01B: Mr Forte Lab access session (level 2, on top of the level-1
# gate above). This is NOT a Sevenef login: it mints a non-persistent synthetic
# visitor scoped to /lab only — no user, no workspace, no /api access.
# NEVER commit real values. Generate them like this (examples, not real values):
#   key:        openssl rand -base64 24
#   key sha256: printf %s "<key>" | shasum -a 256   (store ONLY the 64-hex digest)
#   secret:     openssl rand -base64 48             (independent from AUTH_SECRET)
# SHA-256 (64 hex chars) of the human access key. The plaintext key is never stored.
SEVENEF_LAB_ACCESS_KEY_SHA256=
# Independent HS256 signing secret for the lab token. MUST differ from AUTH_SECRET
# (and from every Google/Turso/Voice Lab secret). Minimum 32 chars.
SEVENEF_LAB_ACCESS_TOKEN_SECRET=
# Session lifetime in minutes. Integer in [15, 480]; default 120 when unset.
SEVENEF_LAB_ACCESS_TTL_MINUTES=120
DEEPSEEK_API_KEY=

# Google OAuth — required for real login (see Google Cloud: OAuth 2.0 Client, Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Server: blocks /api/auth/login/google. Client: /login shows dev form instead of Google. Keep both aligned.
DISABLE_GOOGLE_AUTH=false
NEXT_PUBLIC_DISABLE_GOOGLE_AUTH=false
# Optional: after Google login, set wf_workspace to this id if the user is already a WorkspaceMember (e.g. team "Skina" workspace).
# AUTH_PREFERRED_WORKSPACE_ID=
# Google: invite-only vs self-serve. Unset or any value except "false" = invite-only (AllowedEmail required). Set to false for open SaaS signup.
# AUTH_INVITE_ONLY=false
# New users in self-serve mode only (ignored when invite-only assigns role from AllowedEmail). One of: admin, editor, viewer
AUTH_DEFAULT_USER_ROLE=viewer

# SevenF System Admin (control plane) — bootstrap.
# Comma-separated emails that auto-promote to PlatformAdmin{role: "SUPER_ADMIN"}
# the next time they sign in via Google. Once a row exists in PlatformAdmin the
# env var is no longer needed; CLEAR THIS in production after the first login
# to avoid leaving a self-promotion door open for anyone with .env access.
# This NEVER demotes existing PlatformAdmins, only promotes.
PLATFORM_BOOTSTRAP_EMAILS=

# App URL used by some redirects (e.g. cliente logout fallback)
NEXTAUTH_URL=https://your-production-domain.example

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Email (Resend) — Smart Inbox outbound
RESEND_API_KEY=
INBOX_FROM_EMAIL=inbox@skina.digital
INBOX_FROM_NAME=Skina
