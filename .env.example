AUTH_SECRET=replace-with-a-long-random-secret

# Database (use either DATABASE_* or TURSO_*)
DATABASE_URL=libsql://your-database-url
DATABASE_AUTH_TOKEN=your-database-auth-token
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# AI providers
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Google OAuth — required for real login (see Google Cloud: OAuth 2.0 Client, Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Server: blocks /api/auth/login/google. Client: /login shows dev form instead of Google. Keep both aligned.
DISABLE_GOOGLE_AUTH=false
NEXT_PUBLIC_DISABLE_GOOGLE_AUTH=false
# Optional: after Google login, set wf_workspace to this id if the user is already a WorkspaceMember (e.g. team "Skina" workspace).
# AUTH_PREFERRED_WORKSPACE_ID=
# Google: invite-only vs self-serve. Unset or any value except "false" = invite-only (AllowedEmail required). Set to false for open SaaS signup.
# AUTH_INVITE_ONLY=false
# New users in self-serve mode only (ignored when invite-only assigns role from AllowedEmail). One of: admin, editor, viewer
AUTH_DEFAULT_USER_ROLE=viewer

# App URL used by some redirects (e.g. cliente logout fallback)
NEXTAUTH_URL=https://your-production-domain.example

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Email (Resend) — Smart Inbox outbound
RESEND_API_KEY=
INBOX_FROM_EMAIL=inbox@skina.digital
INBOX_FROM_NAME=Skina
