generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Verticals ──

model Vertical {
  id            String   @id @default(cuid())
  key           String   @unique
  name          String
  description   String?
  defaultConfig String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── Multi-tenancy ──

model Workspace {
  id          String   @id @default(cuid())
  nombre      String
  slug        String   @unique
  vertical    String   @default("creative-agency")
  verticalKey String   @default("creative-agency")
  config      String?
  plan        String   @default("free")
  /// Lifecycle status managed from the SevenF System Admin control plane.
  /// Valid values are mirrored in `core/system/workspace-status.ts`:
  ///   active | trial | suspended | archived
  /// IMPORTANT: this column is observational — no part of the runtime
  /// reads it to gate access. Suspension is administrative-only until a
  /// future enforcement layer is added.
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users          User[]
  clientes       Cliente[]
  proyectos      Proyecto[]
  tareas         Tarea[]
  documentos     Documento[]
  transacciones  Transaccion[]
  facturas       Factura[]
  eventos        Evento[]
  notas          Nota[]
  automatizaciones Automatizacion[]
  notifications  Notification[]
  activities     Activity[]
  inboxEntries   InboxEntry[]
  attachments    Attachment[]
  campaigns      Campaign[]
  contentPieces  ContentPiece[]
  contentIdeas   ContentIdea[]
  members        WorkspaceMember[]
  contacts       Contact[]
  conversations  Conversation[]
  messages       Message[]
  conversationActions ConversationAction[]
  aiClassifications AIClassification[]
  conversationHandoffs ConversationHandoff[]
  conversationDrafts ConversationDraft[]
  conversationReads ConversationRead[]
  forteSnapshot  ForteSnapshot?
  channelConnections ChannelConnection[]
  inboxTodos     InboxTodo[]
  workspaceTasks WorkspaceTask[]
}

model Cliente {
  id          String   @id @default(cuid())
  customId    String?
  nombre      String
  email       String?
  telefono    String?
  empresa     String?
  preferredPaymentMethod String?
  currency    String?
  tipo        String   @default("empresa")
  estado      String   @default("activo")
  notas       String?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace          Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  proyectos          Proyecto[]
  tareas             Tarea[]
  documentos         Documento[]
  transacciones      Transaccion[]
  facturas           Factura[]
  eventos            Evento[]
  notasProfesionales Nota[]
  clientAuth         ClientAuth?
  clientProjects     ClientProject[]
  clientInvoices     ClientInvoice[]
  clientFiles        ClientFile[]
  clientAssets       ClientAsset[]
  clientRequests     ClientRequest[]
  campaigns          Campaign[]
  contacts           Contact[]
  conversations      Conversation[]
}

model Proyecto {
  id                String    @id @default(cuid())
  customId          String?
  nombre            String
  descripcion       String?
  estado            String    @default("planificacion")
  prioridad         String    @default("media")
  progreso          Int       @default(0)
  presupuesto       Float?
  fechaInicio       DateTime?
  fechaFin          DateTime?
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  tags              String?
  internalNotes     String?
  assignedTo        String?
  visibility        String    @default("public")
  allowedUsers      String?
  createdBy         String?
  clienteId         String?
  workspaceId       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  workspace      Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  cliente        Cliente?      @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  tareas         Tarea[]
  documentos     Documento[]
  transacciones  Transaccion[]
  facturas       Factura[]
  eventos        Evento[]
  notas          Nota[]
  campaigns      Campaign[]
  clientRequests ClientRequest[]
  conversations  Conversation[]
}

model Tarea {
  id          String    @id @default(cuid())
  titulo      String
  descripcion String?
  estado      String    @default("pendiente")
  prioridad   String    @default("media")
  fechaLimite DateTime?
  completedAt DateTime?
  proyectoId  String?
  clienteId   String?
  usuarioId   String?
  workspaceId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  proyecto  Proyecto?  @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  cliente   Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  usuario   Usuario?   @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
}

model Documento {
  id          String   @id @default(cuid())
  nombre      String
  tipo        String
  url         String
  tamano      Int?
  clienteId   String?
  proyectoId  String?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  cliente   Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto  Proyecto?  @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
}

model Transaccion {
  id          String   @id @default(cuid())
  tipo        String
  monto       Float
  descripcion String?
  categoria   String?
  fecha       DateTime @default(now())
  clienteId   String?
  proyectoId  String?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  cliente   Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto  Proyecto?  @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
}

model Factura {
  id               String    @id @default(cuid())
  numero           String    @unique
  estado           String    @default("borrador")
  subtotal         Float
  impuesto         Float     @default(0)
  total            Float
  items            String
  fechaEmision     DateTime  @default(now())
  fechaVencimiento DateTime?
  paidAt           DateTime?
  clienteId        String?
  proyectoId       String?
  workspaceId      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  cliente   Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto  Proyecto?  @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
}

model Evento {
  id          String    @id @default(cuid())
  titulo      String
  descripcion String?
  tipo        String    @default("reunion")
  fechaInicio DateTime
  fechaFin    DateTime?
  todoElDia   Boolean   @default(false)
  clienteId   String?
  proyectoId  String?
  workspaceId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  cliente   Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto  Proyecto?  @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
}

model Nota {
  id          String   @id @default(cuid())
  titulo      String
  contenido   String?
  clienteId   String?
  proyectoId  String?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  cliente   Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto  Proyecto?  @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
}

model Automatizacion {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  trigger     String
  condiciones String?
  acciones    String
  estado      String   @default("activa")
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
}

model Usuario {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  rol          String   @default("miembro")
  departamento String?
  estado       String   @default("activo")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tareas Tarea[]
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  nombre          String?
  avatar          String?
  /// @deprecated Legacy global RBAC ("admin" | "editor" | "viewer") used by
  /// `middleware.ts` to gate workspace pages like `/finanzas`, `/admin`, etc.
  /// SHOULD migrate to per-workspace `WorkspaceMember.role` for tenant data
  /// and `PlatformAdmin.role` for the control plane. Do not introduce new
  /// dependencies on this column; new authorisation logic must use one of
  /// those two helpers (`requireRoleInWorkspace` / `requirePlatformRole`).
  role            String   @default("viewer")
  /// @deprecated Visibility flag used by legacy role gating. Same migration
  /// note as `role` above.
  isPrivate       Boolean  @default(false)
  /// @deprecated Per-tenant visibility list used by legacy role gating.
  visibleProjects String?
  /// @deprecated Single-workspace pointer from before multi-tenancy. The
  /// canonical source of "which workspaces does this user belong to" is the
  /// `memberships` relation below.
  workspaceId     String?
  lastLogin       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace     Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  notifications Notification[]
  memberships   WorkspaceMember[]
  platformAdmin PlatformAdmin?
}

// ── Platform / Control Plane ──
//
// PlatformAdmin grants access to the SevenF System Admin area (`/system`).
// Membership here is COMPLETELY ORTHOGONAL to WorkspaceMember:
//   - A PlatformAdmin is NOT automatically a member of any workspace.
//   - Workspace data (Inbox, conversations, clients, etc.) is NEVER readable
//     by virtue of being a PlatformAdmin. Reading customer data requires an
//     explicit Impersonation flow (not yet implemented).
//
// `role` is a string instead of a Prisma enum to stay consistent with the rest
// of this schema (sqlite/libsql + the existing string-based RBAC). Allowed
// values are validated in `core/auth/platform-auth.ts`:
//   SUPER_ADMIN | ADMIN | SUPPORT | BILLING.
model PlatformAdmin {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("SUPPORT")
  createdAt DateTime @default(now())
  createdBy String?  // userId of the platform admin who promoted this user, or "bootstrap-env" for env-driven bootstraps
}

/**
 * Append-only audit trail for the SevenF System Admin control plane.
 *
 * Every mutation done from `/system` (and any sensitive read in the future)
 * lands here so we have a forensic record of who did what to whom.
 *
 * Design notes:
 *   - `actorId` stays a plain string (no FK relation) on purpose. Keeping
 *     audit rows independent of `User.id` means we never silently lose the
 *     trail if a user is deleted later — `onDelete: Cascade` would erase
 *     evidence, which is the opposite of what an audit log should do.
 *   - `metadata` is `String?` (TEXT) holding JSON, consistent with how the
 *     rest of the schema stores JSON (`Workspace.config`,
 *     `ChannelConnection.config|credentials|syncState`). The `logPlatformAudit`
 *     helper sanitises and serialises before writing.
 *   - Indexes target the read patterns of the audit page: scan by actor,
 *     by action, by target, or by recency.
 *   - Rows are NEVER mutated — there are no UPDATE/DELETE endpoints. The
 *     audit endpoint is read-only.
 */
model PlatformAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String
  targetId   String
  metadata   String?  // JSON-serialised, sanitised payload (no secrets, no message bodies)
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        String   @default("MEMBER")
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("viewer")
  createdAt DateTime @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  message     String?
  link        String?
  read        Boolean  @default(false)
  workspaceId String?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id          String   @id @default(cuid())
  module      String
  recordId    String
  type        String
  userId      String?
  userName    String?
  userEmail   String?
  data        String?
  workspaceId String?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
}

model Contact {
  id          String   @id @default(cuid())
  nombre      String?
  email       String?
  telefono    String?
  empresa     String?
  tipo        String   @default("visitante")
  canal       String   @default("manual")
  source      String?
  leadScore   Int?
  metadata    String?
  notas       String?
  clienteId   String?
  workspaceId String
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cliente       Cliente?       @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  conversations Conversation[]
  inboxEntries  InboxEntry[]

  @@index([workspaceId, email])
  @@index([workspaceId, telefono])
  @@index([workspaceId, clienteId])
}

model Conversation {
  id            String   @id @default(cuid())
  contactId     String
  channel       String   @default("manual")
  source        String?
  status        String   @default("new")
  subject       String?
  summary       String?
  intent        String?
  /// Operator-assigned category drawn from the workspace taxonomy
  /// (`Workspace.config.taxonomies.inbox`). Free-form `String?` because
  /// each tenant defines its own vocabulary; validation against the
  /// taxonomy lives in the PATCH endpoint, not at the DB level. Stays
  /// SEPARATE from `intent` (AI-generated free text) on purpose:
  /// `category` is operator-controlled, `intent` is classifier output.
  category      String?
  sector        String?
  leadScore     Int?
  urgency       String   @default("media")
  sentiment     String?
  detectedLanguage String?
  assignedTo    String?
  clienteId     String?
  proyectoId    String?
  isPublic      Boolean  @default(false)
  lastMessageAt DateTime @default(now())
  messageCount  Int      @default(0)
  closedAt      DateTime?
  trashedAt     DateTime?
  connectionId  String?
  workspaceId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace      Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact        Contact              @relation(fields: [contactId], references: [id], onDelete: Cascade)
  cliente        Cliente?             @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto       Proyecto?            @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  connection     ChannelConnection?   @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  messages       Message[]
  actions        ConversationAction[]
  classification AIClassification?
  handoff        ConversationHandoff?
  drafts         ConversationDraft[]
  inboxEntries   InboxEntry[]
  todos          InboxTodo[]

  reads          ConversationRead[]

  @@index([workspaceId, status])
  @@index([workspaceId, lastMessageAt])
  @@index([contactId])
  @@index([clienteId])
  @@index([proyectoId])
  @@index([connectionId])
}

model ConversationRead {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastSeenAt     DateTime @default(now())
  workspaceId    String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, workspaceId])
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  role            String
  direction       String   @default("inbound")
  content         String
  contentType     String   @default("text")
  metadata        String?
  isInternal      Boolean  @default(false)
  sourceMessageId String?
  connectionId    String?
  workspaceId     String
  createdAt       DateTime @default(now())

  workspace    Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  connection   ChannelConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([workspaceId, createdAt])
}

model ConversationAction {
  id             String   @id @default(cuid())
  conversationId String
  type           String
  status         String   @default("suggested")
  source         String   @default("system")
  confidence     Float?
  sourceMessageId String?
  data           String?
  resultId       String?
  resultModule   String?
  approvedBy     String?
  approvedAt     DateTime?
  dismissedAt    DateTime?
  executionNotes String?
  errorMessage   String?
  reviewedBy     String?
  reviewedAt     DateTime?
  workspaceId    String
  createdAt      DateTime @default(now())

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([workspaceId, status])
  @@index([workspaceId, source])
  @@index([workspaceId, sourceMessageId])
}

/**
 * InboxTodo — operator-facing work queue.
 *
 * Distinct from ConversationAction (system-executable AI suggestions: create_event, create_task,
 * etc.) and from Tarea (project-scoped task model). InboxTodo represents concrete units of human
 * work surfaced from the Smart Inbox — "Reply to this client", "Send invoice", "Follow up
 * tomorrow". Free-form `title`, reversible `status`, optional `dueAt`, per-operator `assigneeId`.
 *
 * - `conversationId` is nullable so a To-do can exist without a conversation (manual capture or
 *   automation). When set, it scopes the To-do back to its source thread.
 * - `sourceMessageId`, `sourceActionId`, `sourceNoteId` are all nullable because a To-do may be
 *   created manually (no source) or from any of three signals: a message, a ConversationAction
 *   the operator promoted to a human task, or an internal note. We do NOT FK-constrain these so
 *   that deleting/restoring source records doesn't cascade to the To-do (audit trail stays).
 * - Status flow: open ↔ done | dismissed | waiting. All transitions are reversible — re-opening
 *   to `open` clears completedAt/completedBy and dismissedAt/dismissedReason in the service.
 * - `metadata` is a free JSON string for forward-compat (external links, custom flags). Parsed
 *   safely via parseJson<T>() in the service layer.
 */
model InboxTodo {
  id              String   @id @default(cuid())
  workspaceId     String
  conversationId  String?
  sourceMessageId String?
  sourceActionId  String?
  sourceNoteId    String?

  title           String
  description     String?

  status          String   @default("open")
  priority        String   @default("normal")

  assigneeType    String   @default("me")
  assigneeId      String?

  dueAt           DateTime?
  remindAt        DateTime?

  createdBy       String
  createdSource   String   @default("operator")

  completedAt     DateTime?
  completedBy     String?
  dismissedAt     DateTime?
  dismissedReason String?

  metadata        String?

  /**
   * Forward link to the canonical `WorkspaceTask` row this InboxTodo
   * is mirrored into during the transitional dual-write phase (PR 3).
   *
   * Stored as a nullable scalar without a FK constraint by design:
   *   - Same audit-trail rationale as `sourceActionId` /
   *     `sourceMessageId` — deleting the WorkspaceTask must not
   *     cascade into the InboxTodo row, and vice versa.
   *   - Lets the backfill script run idempotently: an unbacked
   *     InboxTodo (`workspaceTaskId IS NULL`) is exactly the set the
   *     script needs to process. Re-running the script is a no-op
   *     once every row is linked.
   *
   * `null` is the legitimate steady state for rows that pre-date PR 3
   * and have not been backfilled yet, plus any row whose dual-write
   * partially failed and is waiting for the next backfill pass.
   */
  workspaceTaskId String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, dueAt])
  @@index([workspaceId, assigneeId, status])
  @@index([conversationId, status])
  @@index([sourceActionId])
  @@index([sourceMessageId])
  /**
   * Supports two query patterns used by PR 3:
   *   - "Find unbacked todos in this workspace" (backfill driver):
   *     `WHERE workspaceId = ? AND workspaceTaskId IS NULL`
   *   - "Find the InboxTodo that mirrors this WorkspaceTask"
   *     (forensic / inverse-link lookup).
   * Sparse on libSQL/sqlite, so the storage cost is negligible.
   */
  @@index([workspaceId, workspaceTaskId])
}

model AIClassification {
  id                   String   @id @default(cuid())
  conversationId       String   @unique
  intent               String?
  sector               String?
  urgency              String?
  leadScore            Int?
  sentiment            String?
  summary              String?
  suggestedTags        String?
  briefData            String?
  facts                String?
  pendingItems         String?
  risks                String?
  nextBestAction       String?
  confidence           Float?
  model                String?
  promptVersion        String?
  pipelineVersion      String?
  scoreReasoning       String?
  lastProcessedMessageId String?
  lastProcessedAt      DateTime?
  reviewedBy           String?
  reviewedAt           DateTime?
  sourceConversationId String?
  workspaceId          String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([workspaceId, leadScore])
}

model ConversationHandoff {
  id                    String   @id @default(cuid())
  conversationId        String   @unique
  status                String   @default("generated")
  headline              String?
  summary               String?
  facts                 String?
  decisions             String?
  pendingItems          String?
  risks                 String?
  nextRecommendedAction String?
  sourceMessageId       String?
  confidence            Float?
  model                 String?
  promptVersion         String?
  reviewedBy            String?
  reviewedAt            DateTime?
  workspaceId           String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
}

model ConversationDraft {
  id              String   @id @default(cuid())
  conversationId  String
  type            String   @default("ghost_reply")
  status          String   @default("draft")
  title           String?
  content         String
  tone            String?
  targetChannel   String?
  sourceMessageId String?
  generatedFrom   String?
  model           String?
  promptVersion   String?
  reviewedBy      String?
  reviewedAt      DateTime?
  workspaceId     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

