generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Verticals ──

model Vertical {
  id            String   @id @default(cuid())
  key           String   @unique
  name          String
  description   String?
  defaultConfig String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── Multi-tenancy ──

model Workspace {
  id          String   @id @default(cuid())
  nombre      String
  slug        String   @unique
  vertical    String   @default("creative-agency")
  verticalKey String   @default("creative-agency")
  config      String?
  plan        String   @default("free")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users          User[]
  clientes       Cliente[]
  proyectos      Proyecto[]
  tareas         Tarea[]
  documentos     Documento[]
  transacciones  Transaccion[]
  facturas       Factura[]
  eventos        Evento[]
  notas          Nota[]
  automatizaciones Automatizacion[]
  notifications  Notification[]
  activities     Activity[]
  inboxEntries   InboxEntry[]
  attachments    Attachment[]
  campaigns      Campaign[]
  contentPieces  ContentPiece[]
  contentIdeas   ContentIdea[]
  members        WorkspaceMember[]
}

model Cliente {
  id          String   @id @default(cuid())
  customId    String?
  nombre      String
  email       String?
  telefono    String?
  empresa     String?
  tipo        String   @default("empresa")
  estado      String   @default("activo")
  notas       String?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace          Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  proyectos          Proyecto[]
  tareas             Tarea[]
  documentos         Documento[]
  transacciones      Transaccion[]
  facturas           Factura[]
  eventos            Evento[]
  notasProfesionales Nota[]
  clientAuth         ClientAuth?
  clientProjects     ClientProject[]
  clientInvoices     ClientInvoice[]
  clientFiles        ClientFile[]
  clientAssets       ClientAsset[]
  clientRequests     ClientRequest[]
  campaigns          Campaign[]
}

model Proyecto {
  id                String    @id @default(cuid())
  customId          String?
  nombre            String
  descripcion       String?
  estado            String    @default("planificacion")
  prioridad         String    @default("media")
  progreso          Int       @default(0)
  presupuesto       Float?
  fechaInicio       DateTime?
  fechaFin          DateTime?
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  tags              String?
  internalNotes     String?
  assignedTo        String?
  visibility        String    @default("public")
  allowedUsers      String?
  createdBy         String?
  clienteId         String?
  workspaceId       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  workspace      Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  cliente        Cliente?      @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  tareas         Tarea[]
  documentos     Documento[]
  transacciones  Transaccion[]
  facturas       Factura[]
  eventos        Evento[]
  notas          Nota[]
  campaigns      Campaign[]
  clientRequests ClientRequest[]
}

model Tarea {
  id          String    @id @default(cuid())
  titulo      String
  descripcion String?
  estado      String    @default("pendiente")
  prioridad   String    @default("media")
  fechaLimite DateTime?
  completedAt DateTime?
  proyectoId  String?
  clienteId   String?
  usuarioId   String?
  workspaceId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  proyecto  Proyecto?  @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  cliente   Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  usuario   Usuario?   @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
}

model Documento {
  id          String   @id @default(cuid())
  nombre      String
  tipo        String
  url         String
  tamano      Int?
  clienteId   String?
  proyectoId  String?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  cliente   Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto  Proyecto?  @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
}

model Transaccion {
  id          String   @id @default(cuid())
  tipo        String
  monto       Float
  descripcion String?
  categoria   String?
  fecha       DateTime @default(now())
  clienteId   String?
  proyectoId  String?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  cliente   Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto  Proyecto?  @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
}

model Factura {
  id               String    @id @default(cuid())
  numero           String    @unique
  estado           String    @default("borrador")
  subtotal         Float
  impuesto         Float     @default(0)
  total            Float
  items            String
  fechaEmision     DateTime  @default(now())
  fechaVencimiento DateTime?
  paidAt           DateTime?
  clienteId        String?
  proyectoId       String?
  workspaceId      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  cliente   Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto  Proyecto?  @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
}

model Evento {
  id          String    @id @default(cuid())
  titulo      String
  descripcion String?
  tipo        String    @default("reunion")
  fechaInicio DateTime
  fechaFin    DateTime?
  todoElDia   Boolean   @default(false)
  clienteId   String?
  proyectoId  String?
  workspaceId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  cliente   Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto  Proyecto?  @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
}

model Nota {
  id          String   @id @default(cuid())
  titulo      String
  contenido   String?
  clienteId   String?
  proyectoId  String?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  cliente   Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto  Proyecto?  @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
}

model Automatizacion {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  trigger     String
  condiciones String?
  acciones    String
  estado      String   @default("activa")
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
}

model Usuario {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  rol          String   @default("miembro")
  departamento String?
  estado       String   @default("activo")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tareas Tarea[]
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  nombre          String?
  avatar          String?
  role            String   @default("viewer")
  isPrivate       Boolean  @default(false)
  visibleProjects String?
  workspaceId     String?
  lastLogin       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace     Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  notifications Notification[]
  memberships   WorkspaceMember[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        String   @default("MEMBER")
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("viewer")
  createdAt DateTime @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  message     String?
  link        String?
  read        Boolean  @default(false)
  workspaceId String?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id          String   @id @default(cuid())
  module      String
  recordId    String
  type        String
  userId      String?
  userName    String?
  userEmail   String?
  data        String?
  workspaceId String?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
}

model InboxEntry {
  id            String    @id @default(cuid())
  nombre        String?
  email         String?
  telefono      String?
  mensaje       String
  fuente        String    @default("manual")
  tipo          String    @default("consulta")
  categoria     String?
  urgencia      String    @default("media")
  intencion     String?
  resumen       String?
  datosCliente  String?
  datosProyecto String?
  notas         String?
  tags          String?
  estado        String    @default("nuevo")
  aiRaw         String?
  clienteId     String?
  proyectoId    String?
  tareaId       String?
  workspaceId   String?
  archivedAt    DateTime?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
}

model QRCode {
  id        String   @id @default(cuid())
  module    String
  recordId  String
  url       String
  imageData String
  label     String?
  createdBy String?
  createdAt DateTime @default(now())
}

model ClientAuth {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  clienteId    String   @unique
  lastLogin    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model ClientProject {
  id          String   @id @default(cuid())
  clienteId   String
  titulo      String
  descripcion String?
  estado      String   @default("activo")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model ClientInvoice {
  id         String   @id @default(cuid())
  clienteId  String
  monto      Float
  estado     String   @default("pendiente")
  qrCodeUrl  String?
  paymentUrl String?
  createdAt  DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model ClientFile {
  id        String   @id @default(cuid())
  clienteId String
  nombre    String
  url       String
  mimeType  String
  tamano    Int
  createdAt DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model Campaign {
  id           String    @id @default(cuid())
  nombre       String
  descripcion  String?
  estado       String    @default("idea")
  marca        String    @default("general")
  fechaInicio  DateTime?
  fechaFin     DateTime?
  presupuesto  Float?
  objetivos    String?
  clienteId    String?
  proyectoId   String?
  visibility   String    @default("public")
  allowedUsers String?
  createdBy    String?
  workspaceId  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  cliente   Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto  Proyecto?  @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  piezas    ContentPiece[]
}

model ContentPiece {
  id              String    @id @default(cuid())
  titulo          String
  copy            String?
  plataforma      String    @default("instagram")
  tipo            String    @default("post")
  estado          String    @default("idea")
  fechaProgramada DateTime?
  fechaPublicada  DateTime?
  hashtags        String?
  mediaUrl        String?
  mediaType       String?
  enlace          String?
  notas           String?
  responsable     String?
  prioridad       String    @default("media")
  campaignId      String?
  clienteId       String?
  proyectoId      String?
  visibility      String    @default("public")
  createdBy       String?
  workspaceId     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  campaign  Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
}

model ContentIdea {
  id          String   @id @default(cuid())
  titulo      String
  descripcion String?
  categoria   String?
  plataforma  String?
  tags        String?
  estado      String   @default("nueva")
  fuente      String   @default("manual")
  clienteId   String?
  proyectoId  String?
  createdBy   String?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
}

// ── Portal Cliente: Assets ──

model ClientAsset {
  id                   String   @id @default(cuid())
  workspaceId          String
  clienteId            String
  projectId            String?
  requestId            String?
  type                 String   @default("OTHER")
  filename             String
  mimeType             String
  sizeBytes            Int      @default(0)
  url                  String
  createdByPortalUserId String?
  createdAt            DateTime @default(now())

  cliente  Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([clienteId])
  @@index([workspaceId, clienteId])
}

// ── Portal Cliente: Solicitudes ──

model ClientRequest {
  id                   String   @id @default(cuid())
  workspaceId          String
  clienteId            String
  proyectoId           String?
  title                String
  description          String?
  status               String   @default("OPEN")
  priority             String   @default("MEDIUM")
  createdByPortalUserId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  cliente  Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  proyecto Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  assets   ClientRequestAsset[]

  @@index([workspaceId])
  @@index([clienteId])
  @@index([workspaceId, clienteId])
}

model ClientRequestAsset {
  id        String @id @default(cuid())
  requestId String
  assetUrl  String
  assetName String
  createdAt DateTime @default(now())

  request ClientRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model Attachment {
  id          String   @id @default(cuid())
  nombre      String
  url         String
  tipo        String
  tamano      Int
  module      String
  recordId    String
  userId      String?
  userName    String?
  ocrText     String?
  scanStatus  String   @default("pending")
  scanResult  String?
  workspaceId String?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
}
