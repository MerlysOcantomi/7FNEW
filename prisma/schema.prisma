generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Cliente {
  id        String   @id @default(cuid())
  nombre    String
  email     String?
  telefono  String?
  empresa   String?
  tipo      String   @default("empresa")
  estado    String   @default("activo")
  notas     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proyectos          Proyecto[]
  tareas             Tarea[]
  documentos         Documento[]
  transacciones      Transaccion[]
  facturas           Factura[]
  eventos            Evento[]
  notasProfesionales Nota[]
}

model Proyecto {
  id          String    @id @default(cuid())
  nombre      String
  descripcion String?
  estado      String    @default("planificacion")
  prioridad   String    @default("media")
  progreso    Int       @default(0)
  presupuesto Float?
  fechaInicio DateTime?
  fechaFin    DateTime?
  clienteId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  cliente       Cliente?      @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  tareas        Tarea[]
  documentos    Documento[]
  transacciones Transaccion[]
  facturas      Factura[]
  eventos       Evento[]
  notas         Nota[]
}

model Tarea {
  id          String    @id @default(cuid())
  titulo      String
  descripcion String?
  estado      String    @default("pendiente")
  prioridad   String    @default("media")
  fechaLimite DateTime?
  completedAt DateTime?
  proyectoId  String?
  clienteId   String?
  usuarioId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  proyecto Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  cliente  Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  usuario  Usuario?  @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
}

model Documento {
  id         String   @id @default(cuid())
  nombre     String
  tipo       String
  url        String
  tamano     Int?
  clienteId  String?
  proyectoId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cliente  Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
}

model Transaccion {
  id          String   @id @default(cuid())
  tipo        String
  monto       Float
  descripcion String?
  categoria   String?
  fecha       DateTime @default(now())
  clienteId   String?
  proyectoId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cliente  Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
}

model Factura {
  id               String    @id @default(cuid())
  numero           String    @unique
  estado           String    @default("borrador")
  subtotal         Float
  impuesto         Float     @default(0)
  total            Float
  items            String
  fechaEmision     DateTime  @default(now())
  fechaVencimiento DateTime?
  paidAt           DateTime?
  clienteId        String?
  proyectoId       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  cliente  Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
}

model Evento {
  id          String    @id @default(cuid())
  titulo      String
  descripcion String?
  tipo        String    @default("reunion")
  fechaInicio DateTime
  fechaFin    DateTime?
  todoElDia   Boolean   @default(false)
  clienteId   String?
  proyectoId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  cliente  Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
}

model Nota {
  id         String   @id @default(cuid())
  titulo     String
  contenido  String?
  clienteId  String?
  proyectoId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cliente  Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
}

model Automatizacion {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  trigger     String
  condiciones String?
  acciones    String
  estado      String   @default("activa")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Usuario {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  rol          String   @default("miembro")
  departamento String?
  estado       String   @default("activo")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tareas Tarea[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  nombre    String?
  avatar    String?
  role      String   @default("viewer")
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications Notification[]
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("viewer")
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id @default(cuid())
  module    String
  recordId  String
  type      String
  userId    String?
  userName  String?
  userEmail String?
  data      String?
  createdAt DateTime @default(now())
}

model InboxEntry {
  id          String    @id @default(cuid())
  nombre      String?
  email       String?
  telefono    String?
  mensaje     String
  fuente      String    @default("manual")
  tipo        String    @default("consulta")
  categoria   String?
  urgencia    String    @default("media")
  intencion   String?
  resumen     String?
  datosCliente String?
  datosProyecto String?
  notas       String?
  tags        String?
  estado      String    @default("nuevo")
  aiRaw       String?
  clienteId   String?
  proyectoId  String?
  tareaId     String?
  archivedAt  DateTime?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model QRCode {
  id        String   @id @default(cuid())
  module    String
  recordId  String
  url       String
  imageData String
  label     String?
  createdBy String?
  createdAt DateTime @default(now())
}

model Attachment {
  id          String   @id @default(cuid())
  nombre      String
  url         String
  tipo        String
  tamano      Int
  module      String
  recordId    String
  userId      String?
  userName    String?
  ocrText     String?
  scanStatus  String   @default("pending")
  scanResult  String?
  createdAt   DateTime @default(now())
}
